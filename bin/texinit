#!/bin/bash

set -euo pipefail

usage() {
  cat <<'EOT'
Usage:
  texinit [name]
  texinit --mylab [name]
  texinit --watch [name]
  texinit --mylab --watch [name]

Examples:
  texinit
  texinit report
  texinit --mylab
  texinit --mylab report
EOT
}

mode="build"
template="basic"
name="main"
script_dir="$(CDPATH= cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(CDPATH= cd -- "${script_dir}/.." && pwd)"
template_root="${repo_root}/templates/texinit"

while [ $# -gt 0 ]; do
  case "$1" in
    --mylab)
      template="mylab"
      shift
      ;;
    --watch)
      mode="watch"
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    -* )
      echo "Unknown option: $1" >&2
      usage >&2
      exit 1
      ;;
    * )
      name="$1"
      shift
      ;;
  esac
done

tex_file="${name}.tex"

case "$template" in
  basic|mylab)
    template_dir="${template_root}/${template}"
    ;;
  *)
    echo "Error: unknown template: ${template}" >&2
    exit 1
    ;;
esac

if [ ! -d "$template_dir" ]; then
  echo "Error: template directory not found: $template_dir" >&2
  exit 1
fi

targets=("$tex_file" .latexmkrc Makefile .gitignore)
if [ "$template" = "mylab" ]; then
  targets+=(mylab-techrep.sty fig)
fi

for file in "${targets[@]}"; do
  if [ -e "$file" ]; then
    echo "Error: $file already exists in $(pwd)." >&2
    echo "Run this in a new directory, or move/remove the existing files first." >&2
    exit 1
  fi
done

escape_sed_replacement() {
  printf '%s' "$1" | sed 's/[&/]/\\&/g'
}

render_template() {
  local src="$1"
  local dst="$2"
  local escaped_name
  escaped_name="$(escape_sed_replacement "$name")"
  sed "s/__TEX_BASENAME__/${escaped_name}/g" "$src" > "$dst"
}

render_template "${template_dir}/Makefile" Makefile
render_template "${template_dir}/.gitignore" .gitignore
render_template "${template_dir}/.latexmkrc" .latexmkrc
render_template "${template_dir}/main.tex" "$tex_file"

if [ "$template" = "mylab" ]; then
  cp "${template_dir}/mylab-techrep.sty" ./mylab-techrep.sty
  mkdir -p fig
fi

echo "Created: ${tex_file}, .latexmkrc, Makefile, .gitignore"
if [ "$template" = "mylab" ]; then
  echo "Created: mylab-techrep.sty, fig/"
fi

case "$mode" in
  build)
    exec make
    ;;
  watch)
    exec make watch
    ;;
esac
